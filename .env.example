# OpenClaw Team Ops Console
# v0.2 governance preview
# Standalone, read-only, mock-first by default.

# Sidecar
SIDECAR_PORT=4310
SIDECAR_MOCK_SCENARIO=baseline

# Optional single-target metadata for the current runtime.
SIDECAR_TARGET_ID=
SIDECAR_TARGET_NAME=
SIDECAR_TARGET_ENVIRONMENT=
SIDECAR_TARGET_OWNER=

# Optional multi-target registry file.
# Example: ./examples/targets.registry.example.json
SIDECAR_TARGETS_FILE=

# Optional local OpenClaw filesystem adapter.
# Leave these unset to keep mock mode as the default.
# The sidecar switches to the read-only filesystem adapter when any of these are set:
# OPENCLAW_RUNTIME_ROOT / OPENCLAW_STATE_DIR / OPENCLAW_CONFIG_FILE /
# OPENCLAW_CONFIG_PATH / OPENCLAW_WORKSPACE_GLOB / OPENCLAW_PROFILE.
#
# Resolution order:
# 1. state dir: OPENCLAW_RUNTIME_ROOT -> OPENCLAW_STATE_DIR -> profile-derived default
#    (~/.openclaw-<profile> for non-default profiles, otherwise ~/.openclaw)
# 2. config: OPENCLAW_CONFIG_FILE -> OPENCLAW_CONFIG_PATH -> existing config candidate
#    under the state dir -> canonical <stateDir>/openclaw.json
# 3. workspaces: OPENCLAW_WORKSPACE_GLOB -> official ~/.openclaw/workspace* scan
# 4. sessions: config session.store -> per-agent default store -> legacy main-agent
#    fallback <stateDir>/sessions/sessions.json
OPENCLAW_RUNTIME_ROOT=
OPENCLAW_STATE_DIR=
OPENCLAW_CONFIG_FILE=
OPENCLAW_CONFIG_PATH=
OPENCLAW_WORKSPACE_GLOB=
OPENCLAW_PROFILE=

# Informational only. This does not activate the filesystem adapter by itself.
OPENCLAW_SOURCE_ROOT=

# Informational metadata or future adapter inputs.
# These do not currently change runtime behavior in the filesystem adapter.
OPENCLAW_GATEWAY_URL=
OPENCLAW_DASHBOARD_URL=
OPENCLAW_LOG_GLOB=

# Overlay API
OVERLAY_API_PORT=4300
SIDECAR_BASE_URL=http://localhost:4310
SIDECAR_TIMEOUT_MS=5000

# Overlay Web
OVERLAY_WEB_PORT=5173
OVERLAY_API_PROXY_TARGET=http://localhost:4300
HOST_SIDECAR_PORT=4310
HOST_OVERLAY_API_PORT=4300
HOST_OVERLAY_WEB_PORT=5173

# Optional browser-side override.
# Leave empty to use same-origin /api and /health routing.
VITE_OVERLAY_API_URL=
