# OpenClaw Team Ops Console
# v0.2 alpha / governance preview
# Standalone, read-only, mock-first by default.

# Sidecar
SIDECAR_PORT=4310
SIDECAR_MOCK_SCENARIO=baseline

# Optional single-target metadata for the current runtime.
# 当前单个观测目标的可选元数据。
# SIDECAR_TARGET_ID / Stable target ID used in the Targets view.
# 当前目标的稳定 ID，用于 Targets 页面标识。
SIDECAR_TARGET_ID=
# SIDECAR_TARGET_NAME / Human-friendly target name shown in the UI.
# 页面中展示的目标名称。
SIDECAR_TARGET_NAME=
# SIDECAR_TARGET_ENVIRONMENT / Environment label such as development, staging, or production.
# 环境标签，例如 development、staging、production。
SIDECAR_TARGET_ENVIRONMENT=
# SIDECAR_TARGET_OWNER / Owning person or team label for governance views.
# 归属人或归属团队标签，用于治理视图展示。
SIDECAR_TARGET_OWNER=

# Optional multi-target registry file.
# Example: ./examples/targets.registry.example.json
# SIDECAR_TARGETS_FILE / JSON registry file for observing multiple targets in one console.
# 多目标注册表 JSON 文件路径；用于一个控制台同时观察多个 target。
SIDECAR_TARGETS_FILE=

# Optional local OpenClaw filesystem adapter.
# Leave these unset to keep mock mode as the default.
# 可选本地 OpenClaw 文件系统只读 adapter。
# 不填写这些值时，默认保持 mock-first。
# The sidecar switches to the read-only filesystem adapter when any of these are set:
# OPENCLAW_RUNTIME_ROOT / OPENCLAW_STATE_DIR / OPENCLAW_CONFIG_FILE /
# OPENCLAW_CONFIG_PATH / OPENCLAW_WORKSPACE_GLOB / OPENCLAW_PROFILE.
# Recommended official envs: OPENCLAW_STATE_DIR / OPENCLAW_CONFIG_PATH / OPENCLAW_PROFILE
# 推荐优先使用官方环境变量：OPENCLAW_STATE_DIR / OPENCLAW_CONFIG_PATH / OPENCLAW_PROFILE
# Sidecar compatibility aliases: OPENCLAW_RUNTIME_ROOT / OPENCLAW_CONFIG_FILE
# Sidecar 兼容别名：OPENCLAW_RUNTIME_ROOT / OPENCLAW_CONFIG_FILE
#
# Resolution order:
# 1. state dir: OPENCLAW_RUNTIME_ROOT -> OPENCLAW_STATE_DIR -> profile-derived default
#    (~/.openclaw-<profile> for non-default profiles, otherwise ~/.openclaw)
# 2. config: OPENCLAW_CONFIG_FILE -> OPENCLAW_CONFIG_PATH -> existing config candidate
#    under the state dir -> canonical <stateDir>/openclaw.json
# 3. workspaces: OPENCLAW_WORKSPACE_GLOB -> official ~/.openclaw/workspace* scan
# 4. sessions: config session.store -> per-agent default store -> legacy main-agent
#    fallback <stateDir>/sessions/sessions.json
# Example values:
# OPENCLAW_RUNTIME_ROOT=/path/to/your/.openclaw
# OPENCLAW_STATE_DIR=/path/to/your/.openclaw
# OPENCLAW_CONFIG_FILE=/path/to/your/.openclaw/openclaw.json
# OPENCLAW_CONFIG_PATH=/path/to/your/.openclaw/openclaw.json
# OPENCLAW_WORKSPACE_GLOB=/path/to/your/.openclaw/workspace*
# OPENCLAW_PROFILE=default
# OPENCLAW_RUNTIME_ROOT / Sidecar alias for the OpenClaw state dir.
# Sidecar 对 OpenClaw state 目录的兼容别名。
OPENCLAW_RUNTIME_ROOT=
# OPENCLAW_STATE_DIR / Official OpenClaw state directory path.
# OpenClaw 官方 state 目录路径。
OPENCLAW_STATE_DIR=
# OPENCLAW_CONFIG_FILE / Sidecar alias for the OpenClaw config file path.
# Sidecar 对 OpenClaw 配置文件路径的兼容别名。
OPENCLAW_CONFIG_FILE=
# OPENCLAW_CONFIG_PATH / Official OpenClaw config file path.
# OpenClaw 官方配置文件路径。
OPENCLAW_CONFIG_PATH=
# OPENCLAW_WORKSPACE_GLOB / Optional workspace scan override when workspaces are not under the default pattern.
# 可选的 workspace 扫描覆盖规则；当工作区不在默认模式下时使用。
OPENCLAW_WORKSPACE_GLOB=
# OPENCLAW_PROFILE / Optional OpenClaw profile name used to derive default state/config paths.
# 可选的 OpenClaw profile 名称，用于推导默认的 state/config 路径。
OPENCLAW_PROFILE=

# OPENCLAW_SOURCE_ROOT / Optional source-repo path shown as metadata only.
# 可选的 OpenClaw 源码仓库路径，仅用于元数据展示，不参与读取。
# Example / 示例: /path/to/your/openclaw
OPENCLAW_SOURCE_ROOT=

# Overlay API
OVERLAY_API_PORT=4300
SIDECAR_BASE_URL=http://localhost:4310
SIDECAR_TIMEOUT_MS=5000

# Overlay Web
OVERLAY_WEB_PORT=9527
OVERLAY_API_PROXY_TARGET=http://localhost:4300
HOST_SIDECAR_PORT=4310
HOST_OVERLAY_API_PORT=4300
HOST_OVERLAY_WEB_PORT=9527

# Optional browser-side override.
# Leave empty to use same-origin /api and /health routing.
VITE_OVERLAY_API_URL=http://localhost:4300
