# ==============================================================================
# OpenClaw Team Ops Console - Environment Configuration
# OpenClaw Team Ops Console - 环境变量配置
#
# Usage (使用指南):
# 1. Copy this file to `.env` (复制此文件并重命名为 `.env`)
#    ```bash
#    cp .env.example .env
#    ```
# 2. Run local dev server (运行本地开发服务)
#    ```bash
#    corepack pnpm dev
#    ```
#
# Note: By default, the console runs in "mock mode" (simulated data). 
# To read a real local OpenClaw runtime, change OPENCLAW_STATE_DIR below.
# 注意：默认自带“模拟数据(Mock)体验模式”。如果要直连真实的本地 OpenClaw 运行数据，
# 请将下方的 OPENCLAW_STATE_DIR 修改为真实路径。
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Data Source / 核心数据源配置 (一键上手关键)
# ------------------------------------------------------------------------------
# Leave as `/path/to/your/.openclaw` to stay in mock mode.
# Replace with a real path (e.g. `/Users/myname/.openclaw`) to enable 
# read-only filesystem mode connecting to your local OpenClaw.
# 保持为 `/path/to/your/.openclaw` 则使用内置的模拟数据体验功能。
# 替换为真实的 OpenClaw 存储目录（例如 `/Users/myname/.openclaw`），即可开启真实只读模式。
OPENCLAW_STATE_DIR=/path/to/your/.openclaw

# Default mock scenario (options: baseline, partial-coverage, stale-observability, error-upstream).
# 模拟模式下的默认场景配置。
SIDECAR_MOCK_SCENARIO=baseline

# ------------------------------------------------------------------------------
# 2. Core Services Ports / 本地服务端口配置
# ------------------------------------------------------------------------------
# Local ports used when running `corepack pnpm dev`.
# 本地 `corepack pnpm dev` 启动时的服务端口。
SIDECAR_PORT=4310
OVERLAY_API_PORT=4300
OVERLAY_WEB_PORT=5173

# API Request Timeout (in milliseconds) / API 请求超时时间（毫秒）
SIDECAR_TIMEOUT_MS=5000

# ------------------------------------------------------------------------------
# 3. Target Metadata / 目标控制台展示元数据 (可选 / Optional)
# ------------------------------------------------------------------------------
# Optional metadata shown in the UI for a single target.
# 单一目标模式下，在控制台界面中展示的团队/业务身份信息（可选）。
SIDECAR_TARGET_ID=local-evaluation
SIDECAR_TARGET_NAME=Local Preview Target
SIDECAR_TARGET_ENVIRONMENT=development
SIDECAR_TARGET_OWNER=platform-team

# ------------------------------------------------------------------------------
# 4. Multi-Target Registry / 多目标配置 (可选 / Optional)
# ------------------------------------------------------------------------------
# Optional path to a JSON registry file for multiple targets. 
# (See examples/targets.registry.example.json)
# 多目标注册表文件路径（如需同时观察多个目标使用，参考 examples 目录）。
SIDECAR_TARGETS_FILE=

# ------------------------------------------------------------------------------
# 5. Advanced OpenClaw Settings / OpenClaw 高级配置 (可选 / Optional)
# ------------------------------------------------------------------------------
# These settings override defaults if you have a custom or remote OpenClaw setup.
# 仅用于覆盖默认设置的自定义高级配置。
# OPENCLAW_GATEWAY_URL / TOKEN 只用于 sidecar 侧的只读 runtime plane，不会下发到浏览器。
OPENCLAW_PROFILE=
OPENCLAW_GATEWAY_URL=
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_SOURCE_ROOT=

# ------------------------------------------------------------------------------
# 6. Web & UI Settings / Web 前端配置 (可选 / Optional)
# ------------------------------------------------------------------------------
# Optional browser API override. Leave empty to use same-origin `/api` proxy.
# 覆盖前端请求 API 的地址。为空则默认使用同源 `/api` 代理，无需修改。
VITE_OVERLAY_API_URL=

# ------------------------------------------------------------------------------
# 7. Docker Compose Settings / Docker 部署映射配置
# ------------------------------------------------------------------------------
# These ports are mapped to the host when using docker-compose.
# 使用 `docker compose up` 部署时映射到宿主机的访问端口。前端可直接访问 5173。
HOST_SIDECAR_PORT=4310
HOST_OVERLAY_API_PORT=4300
HOST_OVERLAY_WEB_PORT=5173
