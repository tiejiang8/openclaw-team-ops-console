# OpenClaw Team Ops Console v0.1 alpha
# Standalone, read-only, mock-first by default.

# Sidecar
SIDECAR_PORT=4310
SIDECAR_MOCK_SCENARIO=baseline

# Optional local OpenClaw filesystem adapter (Phase 1.4).
# Leave these unset to keep mock mode as the default.
# The sidecar switches to the read-only filesystem adapter when
# OPENCLAW_RUNTIME_ROOT, OPENCLAW_CONFIG_FILE, or OPENCLAW_WORKSPACE_GLOB is set.
OPENCLAW_RUNTIME_ROOT=
OPENCLAW_CONFIG_FILE=
OPENCLAW_WORKSPACE_GLOB=
# Informational only. This does not activate the filesystem adapter by itself.
OPENCLAW_SOURCE_ROOT=

# Overlay API
OVERLAY_API_PORT=4300
SIDECAR_BASE_URL=http://localhost:4310
SIDECAR_TIMEOUT_MS=5000

# Overlay Web
OVERLAY_WEB_PORT=5173
OVERLAY_API_PROXY_TARGET=http://localhost:4300
HOST_SIDECAR_PORT=4310
HOST_OVERLAY_API_PORT=4300
HOST_OVERLAY_WEB_PORT=5173

# Optional browser-side override.
# Leave empty to use same-origin /api and /health routing.
VITE_OVERLAY_API_URL=
