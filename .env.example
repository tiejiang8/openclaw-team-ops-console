# Copy this file to `.env`.
# Leave `OPENCLAW_STATE_DIR` as `/path/to/your/.openclaw` to stay in mock mode.
# Replace only that one path when you want to read a real local OpenClaw runtime.

# Local ports for `corepack pnpm dev`.
SIDECAR_PORT=4310
OVERLAY_API_PORT=4300
OVERLAY_WEB_PORT=5173

# Default mock mode.
SIDECAR_MOCK_SCENARIO=baseline
SIDECAR_TIMEOUT_MS=5000

# Replace this one path to enable read-only filesystem mode.
OPENCLAW_STATE_DIR=/path/to/your/.openclaw

# Optional advanced OpenClaw settings.
OPENCLAW_PROFILE=
OPENCLAW_GATEWAY_URL=
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_SOURCE_ROOT=

# Optional target metadata shown in the UI.
SIDECAR_TARGET_ID=
SIDECAR_TARGET_NAME=
SIDECAR_TARGET_ENVIRONMENT=
SIDECAR_TARGET_OWNER=

# Optional multi-target registry.
SIDECAR_TARGETS_FILE=

# Optional browser API override. Leave empty to use same-origin `/api`.
VITE_OVERLAY_API_URL=

# Only used by Docker Compose.
HOST_SIDECAR_PORT=4310
HOST_OVERLAY_API_PORT=4300
HOST_OVERLAY_WEB_PORT=5173
