# OpenClaw Team Ops Console
# v0.2 alpha filesystem-backed Docker Compose example
# Standalone, read-only, official-env-first

# Host bind mounts
# Point these at the host paths that contain your real OpenClaw state and workspaces.
# If your workspaces live under the same state dir, you can keep both paths identical.
OPENCLAW_STATE_DIR_HOST=/path/to/your/.openclaw
OPENCLAW_WORKSPACE_ROOT_HOST=/path/to/your/.openclaw

# Container-exposed OpenClaw envs
# OPENCLAW_CONFIG_PATH defaults to /openclaw-state/openclaw.json inside the container.
# OPENCLAW_PROFILE is optional and only needed when you want profile-derived defaults.
OPENCLAW_CONFIG_PATH=/openclaw-state/openclaw.json
OPENCLAW_PROFILE=

# Optional override only.
# Leave the default if your workspaces are under /openclaw-state/workspace*.
# Set /openclaw-workspaces/workspace* if the second bind mount is the authoritative root.
OPENCLAW_WORKSPACE_GLOB=/openclaw-state/workspace*

# Optional informational-only metadata
OPENCLAW_SOURCE_ROOT=

# Service ports
HOST_SIDECAR_PORT=4310
HOST_OVERLAY_API_PORT=4300
HOST_OVERLAY_WEB_PORT=5173
SIDECAR_TIMEOUT_MS=5000
