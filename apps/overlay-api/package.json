{
  "name": "@openclaw-team-ops/overlay-api",
  "version": "0.2.0-alpha.0",
  "private": true,
  "type": "module",
  "description": "OpenClaw Team Ops Overlay API - read-only governance aggregation",
  "main": "dist/main.js",
  "types": "dist/main.d.ts",
  "scripts": {
    "dev": "node ../../scripts/run-node-with-root-env.mjs --import tsx src/main.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node ../../scripts/run-node-with-root-env.mjs dist/main.js"
  },
  "dependencies": {
    "@openclaw-team-ops/shared": "workspace:*",
    "cors": "^2.8.5",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "tsx": "^4.19.3"
  }
}
